# Copy to .env and fill in values:
#   copy .env.example .env

# --- Google Places (discovery) ---
# Enable "Places API (New)" in Google Cloud → APIs & Services → Library
GOOGLE_PLACES_API_KEY=

# --- Firecrawl (website enrichment) ---
# https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Google Sheets (lead export) ---
# Spreadsheet ID only — from the URL between /d/ and /edit
# Example: https://docs.google.com/spreadsheets/d/ABC123xyz/edit → ABC123xyz
GOOGLE_SHEETS_SPREADSHEET_ID=

# Path to service account JSON (relative to project root)
# Create in Google Cloud → IAM → Service accounts → Keys → JSON
# Share your sheet with the service account email as Editor
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/google-service-account.json

# Optional: tab name (defaults to "Leads", falls back to first tab)
# GOOGLE_SHEETS_TAB_NAME=Leads

# Optional: Firecrawl enrichment mode — hybrid (default), scrape_only, agent_only
# FIRECRAWL_ENRICHMENT_MODE=hybrid

# Optional: use Firecrawl cache for scrapes (ms); 172800000 = 2 days
# FIRECRAWL_SCRAPE_MAX_AGE_MS=172800000

# Optional: Firecrawl Agent (75+ credits/lead) — disabled by default; eval showed Map+Search+Gateway
# covers property managers, medical, malls. Enable only for stubborn corporate locators.
# FIRECRAWL_AGENT_ENABLED=true

# Optional: cap Firecrawl Agent credits per lead (default 75; set 0 to disable cap)
# FIRECRAWL_AGENT_MAX_CREDITS=75

# Optional: stop enriching leads when a run exceeds this Firecrawl credit estimate (0 = unlimited)
# FIRECRAWL_MAX_CREDITS_PER_RUN=500

# Optional: parallel Firecrawl scrape jobs (Hobby plan = 5)
# FIRECRAWL_MAX_CONCURRENCY=5

# Optional: parallel lead enrichment threads per market run (default 1 = sequential)
# ENRICHMENT_PARALLEL_WORKERS=3

# Optional: domain verification cache TTL in hours (default 24)
# DOMAIN_CACHE_TTL_HOURS=24

# Optional: Agent polling (seconds)
# FIRECRAWL_AGENT_POLL_INTERVAL_S=15
# FIRECRAWL_AGENT_TIMEOUT_S=300

# --- Vercel AI Gateway (Why Call + Talking Points) ---
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=google/gemini-2.5-flash

# Optional: disable sales-copy pass without removing keys
# AI_GATEWAY_ENABLED=false

# Optional: future integrations
# BROWSER_USE_API_KEY=
