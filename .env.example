# Copy to .env and fill in values.
# Dashboard also needs SUPABASE_DB_URL in dashboard/.env.local (can match this file).
# Firecrawl concurrency / place parallelism are inferred from your Firecrawl plan — no knobs here.

# Google Places (New) — https://console.cloud.google.com/apis/library
GOOGLE_PLACES_API_KEY=

# Firecrawl — https://firecrawl.dev
FIRECRAWL_API_KEY=
# Optional scrape knobs (defaults: basic proxy, escalate on dead-end, 2-day maxAge)
# FIRECRAWL_SCRAPE_PROXY=basic
# FIRECRAWL_PROXY_ESCALATE=true
# FIRECRAWL_SCRAPE_MAX_AGE_MS=172800000
# FIRECRAWL_INTERACT_ENABLED=true
# FIRECRAWL_SEARCH_FEEDBACK=true
# FIRECRAWL_MONITOR_READY_PAGES=false
# FIRECRAWL_MONITOR_CRON=0 15 * * 1

# Supabase — https://supabase.com/dashboard/project/<ref>
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres (psycopg + dashboard). Prefer direct over pooler for local ops.
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
