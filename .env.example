# Copy to .env and fill in values:
#   copy .env.example .env

# --- Google Places (discovery) ---
# Enable "Places API (New)" in Google Cloud → APIs & Services → Library
GOOGLE_PLACES_API_KEY=

# --- Firecrawl (website enrichment) ---
# https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Google Sheets (lead export) ---
# Spreadsheet ID only — from the URL between /d/ and /edit
# Example: https://docs.google.com/spreadsheets/d/ABC123xyz/edit → ABC123xyz
GOOGLE_SHEETS_SPREADSHEET_ID=

# Path to service account JSON (relative to project root)
# Create in Google Cloud → IAM → Service accounts → Keys → JSON
# Share your sheet with the service account email as Editor
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/google-service-account.json

# Optional: tab name (defaults to "Leads", falls back to first tab)
# GOOGLE_SHEETS_TAB_NAME=Leads

# Optional: use Firecrawl cache for scrapes (ms); 172800000 = 2 days
# FIRECRAWL_SCRAPE_MAX_AGE_MS=172800000

# Optional: stop enriching leads when a run exceeds this Firecrawl credit estimate (0 = unlimited)
# FIRECRAWL_MAX_CREDITS_PER_RUN=500

# Optional: refuse new runs when total tracked Firecrawl credits exceed this (0 = off)
# FIRECRAWL_SESSION_CREDIT_STOP=2800

# Optional: parallel Firecrawl scrape jobs (Hobby plan = 5)
# FIRECRAWL_MAX_CONCURRENCY=5

# Optional: parallel lead enrichment threads per market run (default 1 = sequential)
# Matches FIRECRAWL_MAX_CONCURRENCY on Hobby (5). AI Gateway spacing auto-scales:
# effective min interval = AI_GATEWAY_MIN_INTERVAL_S × ENRICHMENT_PARALLEL_WORKERS
# ENRICHMENT_PARALLEL_WORKERS=5

# Optional: domain verification cache TTL in hours (default 24)
# DOMAIN_CACHE_TTL_HOURS=24

# --- Vercel AI Gateway (Why Call + Talking Points) ---
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=google/gemini-2.5-flash

# Optional: disable sales-copy pass without removing keys
# AI_GATEWAY_ENABLED=false

# Optional: rate-limit spacing for free-tier models (default 4s between calls;
# multiplied by ENRICHMENT_PARALLEL_WORKERS when running parallel enrichment)
# AI_GATEWAY_MIN_INTERVAL_S=4
# AI_GATEWAY_MAX_RETRIES=5
# AI_GATEWAY_RETRY_BASE_DELAY_S=3
# AI_GATEWAY_RATE_LIMIT_COOLDOWN_S=90

# Optional: minimum lead_score (0-100) for Google Sheets export (default 25)
# MIN_EXPORT_SCORE=25

# --- Browser Use Cloud (owner-chain lookups) ---
# Required for owner-chain / warm-portals; optional for discover-only runs
# https://cloud.browser-use.com — key starts with "bu_"
# Per-task costs land in cost_events; balance snapshots in credit_snapshots (run `pallares-leads doctor`)
BROWSER_USE_API_KEY=
# Set to true after filling in BROWSER_USE_API_KEY (defaults to false in settings.py)
BROWSER_USE_ENABLED=false
BROWSER_USE_BACKEND=cloud
BROWSER_USE_TASK_TIMEOUT_S=300

# Optional: cap expensive Browser Use tiers per run
# OWNER_CHAIN_MAX_PER_RUN=10
# LOOPNET_MAX_PER_RUN=5

# --- Dashboard (dashboard/.env.local, not this file) ---
# PALLARES_DB_PATH=../data/pallares.db
# PROJECT_ROOT=..
# DASHBOARD_API_TOKEN=  # optional bearer token for /api/jobs and /api/export
