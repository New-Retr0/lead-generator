# Copy to .env and fill in values:
#   copy .env.example .env

# --- Google Places (discovery) ---
# Enable "Places API (New)" in Google Cloud → APIs & Services → Library
GOOGLE_PLACES_API_KEY=

# --- Firecrawl (website enrichment) ---
# https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Google Sheets (lead export) ---
# Spreadsheet ID only — from the URL between /d/ and /edit
# Example: https://docs.google.com/spreadsheets/d/ABC123xyz/edit → ABC123xyz
GOOGLE_SHEETS_SPREADSHEET_ID=

# Path to service account JSON (relative to project root)
# Create in Google Cloud → IAM → Service accounts → Keys → JSON
# Share your sheet with the service account email as Editor
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/google-service-account.json

# Optional: future integrations
# BROWSER_USE_API_KEY=
